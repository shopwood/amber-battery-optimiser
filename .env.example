# Copy to .env and fill in. Never commit the real .env.

# Home Assistant
HA_URL=http://homeassistant:8123
HA_TOKEN=                      # long-lived access token (HA → profile → Security)

# Amber
AMBER_TOKEN=
AMBER_SITE_ID=01K1Z85JVTMQNFB3H5CS6YD95Y

# Schedule (local time). Comma-separated for multiple runs per day, e.g. "05:00,17:00".
RUN_AT=05:00
TZ=Australia/Sydney
DRY_RUN=false

# Entities
SOC_ENTITY=sensor.esy_sunhome_1926470123495710721_battery_state_of_charge
GENERAL_PRICE_ENTITY=sensor.01k1z85jvtmqnfb3h5cs6yd95y_general_price
FEED_IN_PRICE_ENTITY=sensor.01k1z85jvtmqnfb3h5cs6yd95y_feed_in_price
SOLCAST_FORECAST_ENTITY=sensor.solcast_pv_forecast_forecast_today

# Battery
BATTERY_CAPACITY_KWH=10.0
BATTERY_SOC_FLOOR_PCT=10.0
BATTERY_SOC_CEILING_PCT=100.0

# Load estimate (refine once you wire up the HA energy dashboard)
DAILY_LOAD_KWH=20.0

# Percentile bands for thresholds
SELL_HIGH_PCT=90
SELL_LOW_PCT=70
BUY_LOW_PCT=10
BUY_MID_PCT=30

# Hard guardrails (applied after the percentile maths)
MIN_SELL_SOC_PCT=20.0          # never sell below this SoC
MAX_BUY_SOC_PCT=80.0           # never buy above this SoC
SELL_PRICE_FLOOR=0.15          # $/kWh — never sell below this feed-in price
